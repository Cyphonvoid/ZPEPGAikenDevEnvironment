{
  "name": "Aiken Cardano Development",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  
  // Customizes the VS Code settings inside the Codespace
  "customizations": {
    "vscode": {
      "extensions": [
        "aiken-lang.aiken", // Automatically installs the Aiken extension
        "ms-python.python"   // RECOMMENDED: Adds Python syntax and terminal support to VS Code
      ]
    }
  },

  // Installs system dependencies, then installs aikup and aiken
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y python3 python3-pip python-is-python3 && curl -sSfL https://install.aiken-lang.org | bash && export PATH=\"$HOME/.aiken/bin:$PATH\" && aikup",

  // Ensures the aiken path is always available in the terminal sessions
  "remoteEnv": {
    "PATH": "${containerEnv:HOME}/.aiken/bin:${containerEnv:PATH}"
  }
}